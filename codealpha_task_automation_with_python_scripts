if __name__ == "__main__":
    source_txt = "raw_text_data.txt"
    destination_txt = "extracted_emails.txt"
    
    # Automate creation of a test file if you don't have one handy
    generate_sample_file(source_txt)
    
    print(f"\nScanning '{source_txt}' for email entries...")
    extract_emails_from_file(source_txt, destination_txt)